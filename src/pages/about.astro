---

import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';

interface ProjectInterface {
  name: string,
  description: string,
  repo?: string,
  liveSite?: string,
  imgSrc?: string,
}

interface SocialLinkInterface {
  content: string,
  url?: string,
  imgSrc?: string,
}

const projects: ProjectInterface[] = [
  {
    "name": "recipile",
    "description": "A full-stack app about recipe collection and management",
    "repo": "https://github.com/roifjcf/recipile"
  },
  {
    "name": "holo-fi",
    "description": "A music player that plays chill lofi music produced by Hololive",
    "repo": "https://github.com/roifjcf/holo-fi",
    "liveSite": "https://roifjcf.github.io/holo-fi/"
  }
];

const socialLinks: SocialLinkInterface[] = [
  {
    "content": "Email: roifjcf@gmail.com"
  },
  {
    "content": "Discord: roifjcf"
  },
  {
    "content": "Github",
    "url": "https://github.com/roifjcf"
  }
];

---

<Layout>
  <header>
    <Navbar />
  </header>
  <main class="about-container">
    <section class="about-intro">
      <p>I'm roifjcf, a... developer?</p>
      <p>
        There's no special meaning of my name,
        it's just a random string of characters I like with a length of seven (one of my favourite numbers).
      </p>
      <p>
        I like building / creating stuff which can be visualized. Programming is one of my ways to share my thoughts and feelings. You may find my creative work elsewhere...
      </p>
    </section>
    <section>
      <h2>Social and contact</h2>
      <ul>
        {socialLinks.map(link =>
          <li>
            {link["url"] ? <a href={link["url"]} target="_blank">{link["content"]}</a> : <p>{link["content"]}</p> }
          </li>
        )}
      </ul>

    </section>
    <section class="">
      <h2>Projects</h2>
      <div class="about-project-container">
        {projects.map(project =>
          <div class="about-project-item-container border-bottom">
            <div class="top">
              <div class="left">
                {project["liveSite"]?
                <h3><a href={project["liveSite"]} target="_blank">{project["name"]}</a></h3> :
                <h3>{project["name"]}</h3>}
              </div>
              <div class="right">
                {project["repo"] && <a href={project["repo"]} target="_blank">Repository</a> }
                {/* {project["liveSite"] && <a href={project["liveSite"]} target="_blank">Live site</a> } */}
              </div>
            </div>
            <div class="bottom">
              <p>{project["description"]}</p>
            </div>
          </div>
        )}
      </div>


    </section>


  </main>
  <!-- background image -->
  <img
    class="background-image"
    src="/avatar-transparent.png"
    alt="background image"
    draggable="false"
  >
</Layout>
